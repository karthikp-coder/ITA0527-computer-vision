import cv2

img = cv2.imread(r"C:\Users\Dell\OneDrive\Pictures\krista-mangulsone-9gz3wfHr65U-unsplash.jpg")

output = img.copy()

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

eye_cascade = cv2.CascadeClassifier(r"C:\Users\Dell\OneDrive\Pictures\haarcascade_eye.xml")

eyes = eye_cascade.detectMultiScale(gray, 1.1, 5)

print("Eyes detected:", len(eyes))

for (x,y,w,h) in eyes:
    cv2.rectangle(output, (x,y), (x+w,y+h), (255,0,0), 2)

img = cv2.resize(img,(500,400))
output = cv2.resize(output,(500,400))

combined = cv2.hconcat([img, output])

cv2.imshow("Input Image | Eye Detection", combined)

cv2.waitKey(0)
cv2.destroyAllWindows()
