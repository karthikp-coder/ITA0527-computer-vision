import cv2

# Read the original image
image = cv2.imread(r"C:\Users\Dell\OneDrive\Pictures\RC.webp")

if image is None:
    print("Error: Image not found.")
else:
    # Resize image to smaller size
    image = cv2.resize(image, (300, 400))

    # Watermark text
    watermark_text = "Bhanu Tej"

    # Position of watermark
    position = (50, 350)

    # Font settings
    font = cv2.FONT_HERSHEY_SIMPLEX

    # Insert watermark text
    cv2.putText(image, watermark_text, position, font, 1,
                (0, 0, 255), 2, cv2.LINE_AA)

    # Display image
    cv2.imshow("Watermarked Image", image)

    # Save watermarked image
    cv2.imwrite(r"C:\Users\Dell\OneDrive\Pictures\watermarked_image.png", image)

    cv2.waitKey(0)
    cv2.destroyAllWindows()
